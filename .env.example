# OncoReconcile AI Environment Configuration
# Copy this file to .env and fill in with your values

# ==================== API Configuration ====================
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development  # Options: development, staging, production

# ==================== LLM Configuration ====================
# Uncomment and fill in the API key for your chosen LLM provider

# OpenAI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4

# Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-3-opus

# Google Gemini
# GOOGLE_API_KEY=your_google_key_here
# GOOGLE_MODEL=gemini-pro

# ==================== External API Configuration ====================
# HGNC API (Gene nomenclature)
HGNC_API_URL=https://rest.genenames.org/search

# ClinVar API (Clinical variants)
CLINVAR_API_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils

# CIViC API (Cancer variant interpretation)
CIVIC_API_URL=https://civicdb.org/api/v2

# ==================== Database Configuration ====================
# DuckDB (default for development)
DATABASE_TYPE=duckdb
DUCKDB_PATH=./data/oncoreconcile.duckdb

# PostgreSQL (for production)
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/oncoreconcile

# ==================== Knowledge Base Configuration ====================
KB_VERSION=0.1
KB_PATH=./data/reference/v0.1
ENABLE_KB_AUTO_UPDATE=false  # Require manual approval for KB updates

# ==================== Logging Configuration ====================
LOG_LEVEL=INFO
LOG_FORMAT=json  # Options: json, text

# ==================== Security ====================
SECRET_KEY=your_secret_key_here_change_in_production
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8501"]

# ==================== Feature Flags ====================
ENABLE_SEMANTIC_SEARCH=false  # Requires SapBERT model
ENABLE_LLM_REASONING=false   # Requires LLM API key
ENABLE_REVIEW_QUEUE=true     # Human review workflow
ENABLE_AUDIT_LOGGING=true    # Track all decisions

# ==================== Debug ====================
DEBUG=false
VERBOSE=false
